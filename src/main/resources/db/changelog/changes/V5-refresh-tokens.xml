<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
  xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

  <changeSet id="14-create-refresh-tokens" author="system">
    <createTable tableName="refresh_tokens">
      <column name="id" type="BIGSERIAL">
        <constraints primaryKey="true" nullable="false"/>
      </column>
      <column name="token_hash" type="VARCHAR(255)">
        <constraints nullable="false" unique="true"/>
      </column>
      <column name="user_id" type="BIGINT">
        <constraints nullable="false"
          foreignKeyName="fk_refresh_user"
          references="users(id)"/>
      </column>
      <column name="company_id" type="BIGINT">
        <constraints nullable="false"
          foreignKeyName="fk_refresh_company"
          references="companies(id)"/>
      </column>
      <column name="expires_at" type="TIMESTAMP">
        <constraints nullable="false"/>
      </column>
      <column name="revoked" type="BOOLEAN" defaultValueBoolean="false">
        <constraints nullable="false"/>
      </column>
      <column name="created_at" type="TIMESTAMP" defaultValueComputed="NOW()">
        <constraints nullable="false"/>
      </column>
      <column name="updated_at" type="TIMESTAMP" defaultValueComputed="NOW()">
        <constraints nullable="false"/>
      </column>
    </createTable>

    <createIndex tableName="refresh_tokens" indexName="idx_refresh_user">
      <column name="user_id"/>
    </createIndex>

    <createIndex tableName="refresh_tokens" indexName="idx_refresh_expires">
      <column name="expires_at"/>
    </createIndex>
  </changeSet>

</databaseChangeLog>
