<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
  xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

  <!-- Replace PHP-generated bcrypt hash with Spring BCryptPasswordEncoder(10) hash of "password" -->
  <changeSet id="16-fix-seed-passwords" author="system">
    <update tableName="users">
      <column name="password_hash"
        value="$2a$10$AJi55uCxPMC54TxzRruwuep/AHVpJS/xe8NpVAFRQO3RQn7dTctT2"/>
      <where>email IN ('admin@aiinterview.com', 'hr@acmetech.com')</where>
    </update>
  </changeSet>

</databaseChangeLog>
